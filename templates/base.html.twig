<!DOCTYPE html>
<html lang="fr">
	<head>
		{% set millecode_meta_title = block('meta_title')|trim ?: 'Millecode | Agence web et mobile à Djibouti' %}
		{% set millecode_meta_description = block('meta_description')|trim ?: 'Millecode est une agence web et mobile basée à Djibouti. Nous concevons des sites web, applications web, applications mobiles, API, solutions métiers, audits techniques et formations full-stack.' %}
		{% set millecode_meta_keywords = block('meta_keywords')|trim ?: 'agence web djibouti, développement web djibouti, création site web djibouti, développement application mobile djibouti, développeur web djibouti, agence développement web et mobile djibouti' %}
		{% set millecode_canonical_url = block('canonical_url')|trim ?: (app.request ? app.request.schemeAndHttpHost ~ app.request.pathInfo : 'https://millecode.com/') %}
		{% set millecode_og_image = block('meta_og_image')|trim ?: absolute_url(asset('assets/images/branding/millecode-logo.jpg')) %}

		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ millecode_meta_title }}</title>
		<meta name="description" content="{{ millecode_meta_description }}">
		<meta name="robots" content="{% block meta_robots %}index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1{% endblock %}">
		<meta name="author" content="Millecode">
		<meta name="keywords" content="{{ millecode_meta_keywords }}">
		<meta name="theme-color" content="#002b5b">
		<link rel="canonical" href="{{ millecode_canonical_url }}">

		<meta property="og:type" content="website">
		<meta property="og:locale" content="fr_FR">
		<meta property="og:site_name" content="Millecode">
		<meta property="og:title" content="{{ millecode_meta_title }}">
		<meta property="og:description" content="{{ millecode_meta_description }}">
		<meta property="og:url" content="{{ millecode_canonical_url }}">
		<meta property="og:image" content="{{ millecode_og_image }}">
		<meta property="og:image:alt" content="Millecode, agence web et mobile à Djibouti">

		<meta name="twitter:card" content="summary_large_image">
		<meta name="twitter:title" content="{{ millecode_meta_title }}">
		<meta name="twitter:description" content="{{ millecode_meta_description }}">
		<meta name="twitter:image" content="{{ millecode_og_image }}">

		<link rel="icon" type="image/png" sizes="32x32" href="{{ asset('assets/images/branding/millecode-icone.png') }}">
		<link rel="icon" type="image/png" sizes="16x16" href="{{ asset('assets/images/branding/millecode-icone.png') }}">
		<link rel="apple-touch-icon" sizes="180x180" href="{{ asset('assets/images/branding/millecode-icone.png') }}">
		<link rel="manifest" href="{{ asset('site.webmanifest') }}">

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
		<link rel="stylesheet" href="{{ asset('assets/css/millecode.css') }}"> {% block stylesheets %}{% endblock %}

		<script type="application/ld+json">
			{
																																																																											            "@context": "https://schema.org",
																																																																											            "@graph": [
																																																																											                {
																																																																											                    "@type": "ProfessionalService",
																																																																											                    "@id": "https://millecode.com/#organization",
																																																																											                    "name": "Millecode",
																																																																											                    "url": "https://millecode.com/",
																																																																											                    "logo": "{{ absolute_url(asset('assets/images/branding/millecode-logo-mark.png')) }}",
																																																																											                    "image": "{{ millecode_og_image }}",
																																																																											                    "description": "{{ millecode_meta_description|e('js') }}",
																																																																											                    "email": "mohamed@millecode.com",
																																																																											                    "telephone": "+25377369958",
																																																																											                    "priceRange": "$$",
																																																																											                    "areaServed": [
																																																																											                        {
																																																																											                            "@type": "Country",
																																																																											                            "name": "Djibouti"
																																																																											                        },
																																																																											                        {
																																																																											                            "@type": "Place",
																																																																											                            "name": "Afrique de l'Est"
																																																																											                        }
																																																																											                    ],
																																																																											                    "address": {
																																																																											                        "@type": "PostalAddress",
																																																																											                        "addressLocality": "Djibouti",
																																																																											                        "addressCountry": "DJ"
																																																																											                    },
																																																																											                    "foundingLocation": {
																																																																											                        "@type": "Place",
																																																																											                        "name": "Djibouti"
																																																																											                    },
																																																																											                    "knowsAbout": [
																																																																											                        "Développement web",
