																																																																											                        "Création de sites web",
																																																																											                        "Applications métiers",
																																																																											                        "API REST",
																																																																											                        "GraphQL",
																																																																											                        "Audit technique",
																																																																											                        "Formation développement web full-stack"
																																																																											                    ]
																																																																											                },
																																																																											                {
																																																																											                    "@type": "WebSite",
																																																																											                    "@id": "https://millecode.com/#website",
																																																																											                    "url": "https://millecode.com/",
																																																																											                    "name": "Millecode",
																																																																											                    "inLanguage": "fr",
																																																																											                    "publisher": {
																																																																											                        "@id": "https://millecode.com/#organization"
																																																																											                    }
																																																																											                },
																																																																											                {
																																																																											                    "@type": "WebPage",
																																																																											                    "@id": "{{ millecode_canonical_url|e('js') }}#webpage",
																																																																											                    "url": "{{ millecode_canonical_url|e('js') }}",
																																																																											                    "name": "{{ millecode_meta_title|e('js') }}",
																																																																											                    "description": "{{ millecode_meta_description|e('js') }}",
																																																																											                    "isPartOf": {
																																																																											                        "@id": "https://millecode.com/#website"
																																																																											                    },
																																																																											                    "about": {
																																																																											                        "@id": "https://millecode.com/#organization"
																																																																											                    },
																																																																											                    "inLanguage": "fr"
																																																																											                }
																																																																											            ]
																																																																											        }
		</script>


	</head>
